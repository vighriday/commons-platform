# ─────────────────────────────────────────────────────────────
# COMMONS — .gitignore
# Keeps secrets and private planning material OUT of the public repo.
# ─────────────────────────────────────────────────────────────

# Private planning workspace — NEVER commit (idea, architecture, seed design,
# build plan, security layer, ledger, drafts, backup video, runbook).
docs/

# Secrets and credentials — committing any of these is a security incident.
.env
.env.*
!.env.example
*.local
*serviceAccount*.json
*service-account*.json
*.pem
*.key
gha-creds-*.json

# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
dist/
dist-ssr/
build/
.vite/

# Runtime store — live submissions + lifecycle deltas (created at runtime, not source)
.data/

# Test / coverage
coverage/
.nyc_output/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor / OS noise
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp

# Firebase / Cloud local artifacts
.firebase/
firebase-debug.log
.firebaserc.local

# Tooling caches
.cache/
.eslintcache
*.tsbuildinfo

# Local editor/tooling state (not part of the product)
.idea/
.vscode/
*.local

# deploy archives (built on demand, never committed)
*.zip

# Full-res evidence-photo originals (re-downloadable from Wikimedia per ATTRIBUTION.md);
# only the served *.web.jpg derivatives are committed.
seed/photos/R033-drain.jpg
seed/photos/R047-pothole.jpg
seed/photos/R064-crack.jpg
