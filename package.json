{
  "name": "commons",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "COMMONS — the operating system for community attention. AI civic intelligence that finds the crises hidden between the reports.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist-server/index.js",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "verify:seed": "tsx scripts/verify-seed.ts",
    "seed": "tsx scripts/genSeed.ts",
    "seed:embeddings": "tsx scripts/genEmbeddings.ts",
    "seed:load": "tsx scripts/loadFirestore.ts",
    "gate": "npm run verify:seed && npm run typecheck && vite build",
    "predeploy": "npm run build && node scripts/checkBundleSecrets.mjs",
    "audit:security": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/react": "^9.0.0",
    "@genkit-ai/google-genai": "^1.0.0",
    "@google/genai": "^1.0.0",
    "@tanstack/react-query": "^5.59.0",
    "compression": "^1.7.4",
    "express": "^5.0.0",
    "express-rate-limit": "^7.4.0",
    "firebase": "^11.0.0",
    "firebase-admin": "^13.0.0",
    "genkit": "^1.0.0",
    "helmet": "^8.0.0",
    "lucide-react": "^0.460.0",
    "maplibre-gl": "^4.7.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^9.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^7.1.7",
    "react-markdown": "^9.0.1",
    "recharts": "^2.13.0",
    "sharp": "^0.33.5",
    "zod": "^4.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.0"
  }
}
