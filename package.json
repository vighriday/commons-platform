{
  "name": "commons",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "COMMONS — the operating system for community attention. AI civic intelligence that finds the crises hidden between the reports.",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx --watch server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "verify:seed": "tsx scripts/verify-seed.ts",
    "verify:freeze": "tsx scripts/verifyFreeze.ts",
    "agents": "node --env-file=.env --import tsx scripts/runAgents.ts",
    "seed": "tsx scripts/genSeed.ts",
    "seed:grids": "tsx scripts/genGrids.ts",
    "seed:issues": "tsx scripts/deriveIssues.ts",
    "seed:embeddings": "node --env-file=.env --import tsx scripts/genEmbeddings.ts",
    "seed:snapshots": "tsx scripts/genSnapshots.ts",
    "seed:footprints": "tsx scripts/genFootprints.ts",
    "seed:all": "npm run seed:grids && npm run seed && npm run seed:issues && npm run agents && npm run seed:snapshots && npm run seed:footprints",
    "gate": "npm run typecheck && vite build",
    "predeploy": "npm run build && node scripts/checkBundleSecrets.mjs",
    "audit:security": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@deck.gl/core": "^9.0.0",
    "@deck.gl/layers": "^9.0.0",
    "@deck.gl/mapbox": "^9.3.4",
    "@deck.gl/react": "^9.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^2.4.0",
    "@tanstack/react-query": "^5.59.0",
    "compression": "^1.7.4",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.0",
    "firebase": "^11.0.0",
    "firebase-admin": "^14.1.0",
    "helmet": "^8.0.0",
    "lucide-react": "^0.546.0",
    "maplibre-gl": "^4.7.0",
    "pino": "^9.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-map-gl": "^7.1.7",
    "react-markdown": "^9.0.1",
    "recharts": "^2.13.0",
    "sharp": "^0.33.5",
    "tsx": "^4.21.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@tailwindcss/vite": "^4.1.14",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.8.2",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
