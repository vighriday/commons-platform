# ─────────────────────────────────────────────────────────────
# COMMONS — environment variables (example)
# Copy to ".env" for local development. NEVER commit a real ".env".
#
# Rule: anything the BROWSER may see is prefixed VITE_ and is PUBLIC by design.
# Anything secret has NO VITE_ prefix and is read only by the server.
# ─────────────────────────────────────────────────────────────

# ── Server-side secrets (NEVER expose to the client, NEVER prefix with VITE_) ──
# Gemini API key from Google AI Studio. On Cloud Run this is injected as a secret.
GEMINI_API_KEY=

# Data Commons API key (free, no credit card) — used at build time only.
DATACOMMONS_API_KEY=

# Port the Express server listens on (Cloud Run sets this automatically).
PORT=8080

# ── Public client config (safe to expose; Firebase web config is public) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Firebase App Check site key (reCAPTCHA v3 — card-free). Public by design.
VITE_RECAPTCHA_V3_SITE_KEY=
